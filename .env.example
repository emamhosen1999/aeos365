APP_NAME=aeos365
# For LOCAL: APP_ENV=local, APP_DEBUG=true, http://aeos365.test
# For PRODUCTION: Update below with your Namecheap domain
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://aeos365.com
APP_DOMAIN=aeos365.com
ADMIN_DOMAIN=admin.aeos365.com
PLATFORM_DOMAIN=aeos365.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

INSTALLATION_SECRET_HASH=$2y$10$KPYdv5U6b/ViDNc6y6qe9.d05R7PMfCSWySMA9ACHInMEC/3E7yFi




APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yourusername_aeos365
DB_USERNAME=yourusername_dbuser
DB_PASSWORD=your_database_password

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.aeos365.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=smtp.namecheap.com
MAIL_PORT=465
MAIL_USERNAME=your_email@aeos365.com
MAIL_PASSWORD=your_email_password
MAIL_FROM_ADDRESS=noreply@aeos365.com
MAIL_FROM_NAME=Aero Enterprise Suite
MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

APP_TIMEZONE=UTC
MAIL_ENCRYPTION=tls

# Aero Platform Mode: 'saas' for multi-tenant SaaS, 'standalone' for single-tenant
AERO_MODE=saas
