{
    "name": "aero/i18n",
    "description": "Aero I18n Package - Internationalisation infrastructure: locale config, middleware, translation dictionaries, and locale switching API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "i18n",
        "laravel",
        "translation",
        "locale",
        "internationalisation"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\I18n\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\I18n\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\I18n\\AeroI18nServiceProvider"
            ]
        },
        "aero": {
            "package": "i18n",
            "version": "1.0.0",
            "category": "foundation",
            "description": "Internationalisation: locale config, middleware, dictionaries, locale switching"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
