{
    "name": "aero/cms",
    "description": "Aero CMS - Block-based Page Builder with HeroUI Components",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "aero",
        "cms",
        "page-builder",
        "heroui",
        "laravel",
        "inertia"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aero/core": "*",
        "aero/hrmac": "*",
        "laravel/framework": "^11.0|^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "spatie/laravel-medialibrary": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Cms\\": "src/",
            "Aero\\Cms\\Database\\Factories\\": "database/factories/",
            "Aero\\Cms\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Cms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Cms\\Providers\\CmsServiceProvider"
            ],
            "aliases": {
                "AeroCms": "Aero\\Cms\\Facades\\Cms"
            }
        },
        "aero": {
            "package": "cms",
            "version": "1.0.0",
            "category": "platform",
            "description": "Block-based CMS for building public pages with HeroUI components",
            "has-assets": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
