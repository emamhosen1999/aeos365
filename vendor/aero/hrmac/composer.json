{
    "name": "aero/hrmac",
    "description": "Hierarchical Role-Module Access Control for Aero Enterprise Suite",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Aero Team",
            "email": "dev@aeroenterprise.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\HRMAC\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\HRMAC\\HRMACServiceProvider"
            ],
            "aliases": {
