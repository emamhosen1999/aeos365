<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # ========================================================
    # SKIP: Real files and directories
    # ========================================================
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ========================================================
    # WORDPRESS: Subdirectory routing  
    # ========================================================
    
    # Skip if already trying to access /wordpress/
    RewriteCond %{REQUEST_URI} ^/wordpress
    RewriteRule ^ - [L]
    
    # WordPress admin paths
    RewriteRule ^wp-admin(/.*)?$ wordpress/wp-admin$1 [QSA,L]
    
    # WordPress includes and content
    RewriteRule ^wp-includes(/.*)?$ wordpress/wp-includes$1 [QSA,L]
    RewriteRule ^wp-content(/.*)?$ wordpress/wp-content$1 [QSA,L]
    
    # WordPress XML-RPC and API
    RewriteRule ^xmlrpc\.php$ wordpress/xmlrpc.php [QSA,L]
    RewriteRule ^wp-json(/.*)?$ wordpress/wp-json$1 [QSA,L]
    
    # All other wp-*.php files
    RewriteRule ^wp-.*\.php$ wordpress/index.php [QSA,L]

    # ========================================================
    # LARAVEL: Explicit routes
    # ========================================================
    
    # These routes must go to Laravel, not WordPress
    RewriteCond %{REQUEST_URI} ^/(register|login|logout|password|reset|email|forgot|api|admin|tenant|dashboard|storage|build)(/|$) [NC]
    RewriteRule ^ index.php [QSA,L]

    # Static files - don't redirect
    RewriteCond %{REQUEST_URI} ^/(favicon\.ico|robots\.txt|manifest\.json|sitemap\.xml|\.well-known)(/|$) [NC]
    RewriteRule ^ - [L]

    # Redirect trailing slashes for non-directories
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ========================================================
    # DEFAULT: Everything else to WordPress
    # ========================================================
    # This catches the root / and any unknown URLs and sends them to WordPress
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ wordpress/index.php [QSA,PT,L]
</IfModule>